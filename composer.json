{
  "config": {
    "vendor-dir": "includes/vendor",
    "allow-plugins": {
      "composer/installers": true,
      "automattic/jetpack-autoloader": true
    }
  },
  "name": "simplesalestax/simplesalestax",
  "description": "Sales tax compliance solution for WooCommerce.",
  "type": "project",
  "require": {
    "bporcelli/php-taxcloud": "1.0.2"
  },
  "license": "GPL-3.0+",
  "authors": [
    {
      "name": "The WooTax Corporation",
      "email": "support@simplesalestax.com"
    }
  ],
  "require-dev": {
    "woocommerce/woocommerce-blocks": "^11.7"
  },
  "extra": {
    "installer-paths": {
      "includes/vendor/{$name}/": ["woocommerce/woocommerce-blocks"]
    }
  }
}
